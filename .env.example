# Environment Variables — Team Task Manager Server

# Server
PORT=5000
NODE_ENV=development

# MongoDB
# Option 1: Local MongoDB
MONGO_URI=mongodb://localhost:27017/team-task-manager
# Option 2: MongoDB Atlas (comment out the local one above and use this)
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/team-task-manager?retryWrites=true&w=majority

# JWT
ACCESS_TOKEN_SECRET=your_super_secret_access_token_key_change_in_production
REFRESH_TOKEN_SECRET=your_super_secret_refresh_token_key_change_in_production
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS
CLIENT_URL=http://localhost:5173
